<!DOCTYPE html>
<html lang="ko">

<head>
    <meta charset="UTF-8">
    <title>자격증</title>

    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/jobsite.css">
</head>

<body>

    <%- include('includes/header') %>
        <%- include('includes/navbar') %>

            <div class="job-wrapper">
                <!-- 자격증 사이트 -->
                <div class="section-title">📚 자격증 & 시험 사이트</div>

                <div class="job-grid">

                    <a href="https://www.q-net.or.kr" target="_blank" class="job-card">
                        <img src="/images/jobsite/qnet.png" class="job-logo">
                        <div class="job-info">
                            <h2>Q-Net</h2>
                            <p>국가자격증 공식 사이트</p>
                        </div>
                        <span class="job-arrow">→</span>
                    </a>

                    <a href="https://exam.toeic.co.kr" target="_blank" class="job-card">
                        <img src="/images/jobsite/toeic.png" class="job-logo">
                        <div class="job-info">
                            <h2>TOEIC</h2>
                            <p>영어 능력 시험</p>
                        </div>
                        <span class="job-arrow">→</span>
                    </a>

                    <a href="https://www.jlpt.jp" target="_blank" class="job-card">
                        <img src="/images/jobsite/jlpt.png" class="job-logo">
                        <div class="job-info">
                            <h2>JLPT</h2>
                            <p>일본어 능력 시험</p>
                        </div>
                        <span class="job-arrow">→</span>
                    </a>
                </div>

                <!-- 개발자 추천 자격증 -->
                <div class="section-title">🧠 개발자 추천 자격증</div>

                <div class="job-grid">

                    <!-- SQLD -->
                    <a href="https://www.dataq.or.kr/www/sub/a_04.do" target="_blank" class="job-card">
                        <img src="/images/jobsite/sqld.png" class="job-logo">
                        <div class="job-info">
                            <h2>SQLD</h2>
                            <p>데이터베이스 설계 · SQL 기본 역량</p>
                        </div>
                        <span class="job-arrow">→</span>
                    </a>

                    <!-- 리눅스마스터 -->
                    <a href="https://www.ihd.or.kr/guidecert1.do" target="_blank" class="job-card">
                        <img src="/images/jobsite/linux.png" class="job-logo">
                        <div class="job-info">
                            <h2>리눅스마스터</h2>
                            <p>서버 운영 · 리눅스 시스템 이해</p>
                        </div>
                        <span class="job-arrow">→</span>
                    </a>

                    <!-- ADsP -->
                    <a href="https://www.dataq.or.kr/www/sub/a_05.do" target="_blank" class="job-card">
                        <img src="/images/jobsite/adsp.png" class="job-logo">
                        <div class="job-info">
                            <h2>ADsP</h2>
                            <p>데이터 분석 기초 · 통계 이해</p>
                        </div>
                        <span class="job-arrow">→</span>
                    </a>

                    <!-- AWS -->
                    <a href="https://aws.amazon.com/certification/certified-cloud-practitioner/" target="_blank"
                        class="job-card">
                        <img src="/images/jobsite/aws.png" class="job-logo">
                        <div class="job-info">
                            <h2>AWS CCP</h2>
                            <p>클라우드 기본 · AWS 입문 자격증</p>
                        </div>
                        <span class="job-arrow">→</span>
                    </a>

                </div>
            </div>
</body>